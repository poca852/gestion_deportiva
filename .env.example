# ============================================================
# Ejemplo de variables de entorno
# ============================================================
# Copia este archivo a:
#   .env             → desarrollo local (ng serve)
#   .env.staging     → pruebas (ng build --configuration=staging)
#   .env.production  → producción (ng build --configuration=production)
#
# Prefijo obligatorio: NG_APP_ (definido en @ngx-env/builder)

# NG_APP_ENV: "development" | "staging" | "production"
NG_APP_ENV=development

NG_APP_SUPABASE_URL=https://your-project-ref.supabase.co
NG_APP_SUPABASE_ANON_KEY=your-anon-key
